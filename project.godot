; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Fabulous Fabio"
config/version="v0.2.1"
run/main_scene="uid://c0v3nvjalfydh"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.67451, 0.196078, 0.196078, 1)
boot_splash/image="uid://jt0wkwaa23pg"
config/icon="uid://jt0wkwaa23pg"
boot_splash/minimum_display_time=3000

[autoload]

CS="*res://entities/coin/coin_spawner.gd"
HS="*res://entities/health/health_spawner.gd"
SS="*res://utilities/save_system/save_system.gd"
FTS="*res://utilities/floating_text_spawner/floating_text_spawner.gd"
AS="*res://utilities/audio_spawner/audio_spawner.gd"
GM="*uid://b8dyp2poy1nia"
CPS="*uid://cnj8nvyxyv6ss"

[display]

window/size/viewport_width=256
window/size/viewport_height=240
window/size/window_width_override=512
window/size/window_height_override=480
window/stretch/mode="viewport"

[file_customization]

folder_colors={
"res://assets/": "red",
"res://common/": "orange",
"res://config/": "yellow",
"res://entities/": "green",
"res://localization/": "teal",
"res://stages/": "blue",
"res://ui/": "purple",
"res://utilities/": "pink"
}

